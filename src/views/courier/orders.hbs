<section>
  <h1>Курьерские заказы</h1>
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Клиент</th>
        <th>Телефон</th>
        <th>Адрес</th>
        <th>Слот</th>
        <th>Статус</th>
        <th>Курьер</th>
        <th>Подтверждения</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
        <tr>
          <td>{{id}}</td>
          <td>{{client_name}}</td>
          <td>{{phone}}</td>
          <td>{{city}}, {{street}}, {{house}}</td>
          <td>{{slot_label}}</td>
          <td>{{status}}</td>
          <td>{{#if courier_name}}{{courier_name}}{{else}}Не назначен{{/if}}</td>
          <td>
            Курьер: {{#if courier_confirmed_at}}Да{{else}}Нет{{/if}}<br />
            Клиент: {{#if client_confirmed_at}}Да{{else}}Нет{{/if}}
          </td>
          <td>
            {{#if courier_id}}
              {{#if courier_confirmed_at}}
                <span class="category">Ожидание клиента</span>
              {{else}}
                <form method="post" action="/courier/orders/{{id}}/confirm" class="inline-form">
                  <button class="btn" type="submit">Подтвердить доставку</button>
                </form>
              {{/if}}
            {{else}}
              <form method="post" action="/courier/orders/{{id}}/accept" class="inline-form">
                <button class="btn" type="submit">Принять заказ</button>
              </form>
            {{/if}}
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>

