<section>
  <h1>Профиль</h1>

  {{#if errors}}
    <ul class="errors">
      {{#each errors}}
        <li>{{this}}</li>
      {{/each}}
    </ul>
  {{/if}}

  <div class="profile-layout">
    <div class="card profile-avatar-box">
      <img src="{{#if user.avatar_path}}/uploads/{{user.avatar_path}}{{else}}/public/img/placeholder.svg{{/if}}" alt="Аватар" class="profile-avatar" />
      <p class="category">Роль: {{user.role_code}}</p>
    </div>

    <form method="post" enctype="multipart/form-data" class="form card">
      <label>ФИО
        <input type="text" name="full_name" value="{{user.full_name}}" required />
      </label>
      <label>Email
        <input type="email" name="email" value="{{user.email}}" required />
      </label>
      <label>Телефон
        <input type="text" name="phone" value="{{user.phone}}" required />
      </label>
      <label>Аватар (jpg, jpeg, png, webp)
        <input type="file" name="avatar" accept=".jpg,.jpeg,.png,.webp" />
      </label>
      <a class="btn btn-secondary" href="/profile/password">Перейти к смене пароля</a>
      <button class="btn" type="submit">Сохранить изменения</button>
    </form>
  </div>

  <section class="card" style="margin-top: 16px;">
    <h2>Мои заказы</h2>
    {{#if orders.length}}
      <table class="admin-table">
        <thead><tr><th>ID</th><th>Статус</th><th>Курьер</th><th>Слот</th><th>Итого</th><th>Подтверждения</th><th>Действия</th></tr></thead>
        <tbody>
          {{#each orders}}
            <tr>
              <td>{{id}}</td>
              <td>{{status}}</td>
              <td>{{#if courier_name}}{{courier_name}}{{else}}Не назначен{{/if}}</td>
              <td>{{slot_label}}</td>
              <td>{{formatCurrency total}}</td>
              <td>
                Курьер: {{#if courier_confirmed_at}}Да{{else}}Нет{{/if}}<br />
                Клиент: {{#if client_confirmed_at}}Да{{else}}Нет{{/if}}
              </td>
              <td>
                <a class="btn btn-secondary" href="/profile/orders/{{id}}">Подробнее</a>
                {{#if client_confirmed_at}}
                  <span class="category">Доставка подтверждена</span>
                {{else}}
                  {{#if courier_confirmed_at}}
                    <form method="post" action="/profile/orders/{{id}}/confirm-delivery" class="inline-form">
                      <button class="btn" type="submit">Подтвердить получение</button>
                    </form>
                  {{else}}
                    <span class="category">Ожидается подтверждение курьера</span>
                  {{/if}}
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p>У вас пока нет заказов.</p>
    {{/if}}
  </section>

</section>
