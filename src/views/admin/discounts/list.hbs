<section>
  <h1>Скидки</h1>
  <form method="get" class="filters">
    <input type="text" name="search" value="{{search}}" placeholder="Поиск" />
    <button class="btn" type="submit">Найти</button>
    <a class="btn" href="/admin/discounts/new">Добавить</a>
  </form>

  <table class="admin-table">
    <thead><tr><th>ID</th><th>Название</th><th>Scope</th><th>Промокод</th><th>Тип</th><th>Значение</th><th>Активна</th><th>Действия</th></tr></thead>
    <tbody>
      {{#each items}}
        <tr>
          <td>{{id}}</td>
          <td>{{name}}</td>
          <td>{{scope}}</td>
          <td>{{promo_code}}</td>
          <td>{{discount_type}}</td>
          <td>{{discount_value}}</td>
          <td>{{#if is_active}}Да{{else}}Нет{{/if}}</td>
          <td>
            <a class="btn" href="/admin/discounts/{{id}}/edit">Изменить</a>
            <form class="inline-form" method="post" action="/admin/discounts/{{id}}/delete">
              <button class="btn" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
