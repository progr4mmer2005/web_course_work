<section>
  <h1>Товары</h1>
  <form method="get" class="filters">
    <input type="text" name="search" value="{{search}}" placeholder="Поиск" />
    <button class="btn" type="submit">Найти</button>
    <a class="btn" href="/admin/products/new">Добавить</a>
  </form>

  <table class="admin-table">
    <thead><tr><th>ID</th><th>Название</th><th>SKU</th><th>Категория</th><th>Цена</th><th>Остаток</th><th>Действия</th></tr></thead>
    <tbody>
      {{#each items}}
        <tr>
          <td>{{id}}</td>
          <td>{{name}}</td>
          <td>{{sku}}</td>
          <td>{{category_name}}</td>
          <td>{{formatCurrency price}}</td>
          <td>{{stock_quantity}}</td>
          <td>
            <a class="btn" href="/admin/products/{{id}}/edit">Изменить</a>
            <form class="inline-form" method="post" action="/admin/products/{{id}}/delete">
              <button class="btn" type="submit">Удалить</button>
            </form>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
