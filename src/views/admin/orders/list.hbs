<section>
  <h1>Заказы</h1>
  <form method="get" class="filters">
    <input type="text" name="search" value="{{search}}" placeholder="Поиск (ID, клиент, email, телефон)" />
    <select name="status">
      <option value="" {{#if (eq status "")}}selected{{/if}}>Все статусы</option>
      <option value="new" {{#if (eq status "new")}}selected{{/if}}>new</option>
      <option value="confirmed" {{#if (eq status "confirmed")}}selected{{/if}}>confirmed</option>
      <option value="packing" {{#if (eq status "packing")}}selected{{/if}}>packing</option>
      <option value="delivery" {{#if (eq status "delivery")}}selected{{/if}}>delivery</option>
      <option value="delivered" {{#if (eq status "delivered")}}selected{{/if}}>delivered</option>
      <option value="canceled" {{#if (eq status "canceled")}}selected{{/if}}>canceled</option>
    </select>
    <button class="btn" type="submit">Найти</button>
  </form>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Клиент</th>
        <th>Телефон</th>
        <th>Адрес</th>
        <th>Слот</th>
        <th>Статус</th>
        <th>Курьер</th>
        <th>Подтверждения</th>
        <th>Итого</th>
        <th>Дата</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
        <tr>
          <td>{{id}}</td>
          <td>{{user_name}}<br /><small>{{user_email}}</small></td>
          <td>{{phone}}</td>
          <td>{{city}}, {{street}}, {{house}}</td>
          <td>{{slot_label}}</td>
          <td>{{status}}</td>
          <td>{{#if courier_name}}{{courier_name}}{{else}}Не назначен{{/if}}</td>
          <td>
            Курьер: {{#if courier_confirmed_at}}Да{{else}}Нет{{/if}}<br />
            Клиент: {{#if client_confirmed_at}}Да{{else}}Нет{{/if}}
          </td>
          <td>{{formatCurrency total}}</td>
          <td>{{created_at}}</td>
          <td>
            <a class="btn" href="/admin/orders/{{id}}/edit">Изменить</a>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
